# Copy to /etc/autotim/autotim.env, mode 600, owned by the autotim
# user. Referenced by systemd's EnvironmentFile= directive in
# autotim.service. Never commit the real file — see
# docs/security/public-private-boundary.md.
#
# These environment variables override the matching keys in
# /etc/autotim/config.toml, per the AUTOTIM_SECTION__KEY convention
# (doc 11). Use this file for exactly the values that should not sit
# in a TOML file on disk even briefly during editing — the database
# password and the Secrets unseal passphrase.

AUTOTIM_DATABASE__URL=postgres://autotim:REPLACE_ME@127.0.0.1:5432/autotim
AUTOTIM_SECRETS__PASSPHRASE=REPLACE_WITH_UNSEAL_PASSPHRASE
