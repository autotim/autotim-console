{
  "name": "autotim-console-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Autotim Console — Vue 3 + PrimeVue frontend, mobile-first (doc 50). Embedded into the autotim binary via rust-embed (doc 10).",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc -b --noEmit"
  },
  "dependencies": {
    "vue": "^3.4.0",
    "vue-router": "^4.3.0",
    "pinia": "^2.1.0",
    "primevue": "^4.0.0",
    "primeicons": "^7.0.0",
    "vue-i18n": "^9.13.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.4.0",
    "vite": "^5.2.0",
    "vue-tsc": "^2.0.0"
  }
}
